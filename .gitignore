# Generated by Cargo

# will have compiled files and executables

debug/
target/

# These are backup files generated by rustfmt

**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information

*.pdb

# Generated by cargo mutants

# Contains mutation testing data

**/mutants.out*/

# RustRover / JetBrains

# JetBrains specific template is maintained in a separate JetBrains.gitignore that can

# be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore

# and can be added to the global gitignore or merged into this file.

# For a more nuclear option, uncomment the following to ignore the entire idea folder.

#.idea/

# OS files

.DS_Store
Thumbs.db

# Editor files

.vscode/
*.swp
*.swo

# Local logs

*.log

# Local temporary files

tmp/
temp/
*.tmp

# Local test or scratch files

oneline.txt

# cargo-ac local credentials / sessions

*.cookie
session.cookie
session.json
cookies.json
cookie_store.json

# cargo-ac local cache / debug output

.cache/
debug-html/
debug_html/
*.debug.html

# AtCoder parser failure snapshots

atcoder-debug/
atcoder-debug-html/

# Local environment files

.env
.env.*
!.env.example
